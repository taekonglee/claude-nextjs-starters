{
  "permissions": {
    "allow": [
      "Web Search",
      "WebFetch",
      "Bash",
      "Bash(npm install:*)",
      "Bash(npx shadcn@latest:*)",
      "mcp__playwright"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "playwright"
  ],
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/permission-request.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/task-complete.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log-command.sh"
          }
        ]
      }
    ]
  },
  "outputStyle": "Explanatory"
}
